# 給 db.py / alembic 使用（同步 psycopg2 驅動，操作 public schema）
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@127.0.0.1:5432/dbname

LLM_PROVIDER=openai
BASE_URL=http://127.0.0.1:1235/v1
LLM_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

FOOBAR_CLIENT_ID=chainlit_app
FOOBAR_CLIENT_SECRET=FOOBAR_CLIENT_SECRET
# 逗號分隔要啟用的自定義 OAuth provider；留空則自動偵測（依環境變數是否齊全）
OAUTH_CUSTOM_PROVIDERS=foobar

CHAINLIT_AUTH_SECRET=
# 多服務同機部署時，以下兩個值每個服務需設不同，避免瀏覽器 cookie 互相干擾
SESSION_SECRET_KEY=
CHAINLIT_AUTH_COOKIE_NAME=access_token

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

CHAINLIT_URL=http://localhost:8000

# 是否啟用 session 歷史紀錄功能（包含前端查詢歷史按鈕）。預設 true，設為 false 可完全停用
ENABLE_SESSION_HISTORY=true

# http_request 工具的 proxy 設定（選填）
TOOL_HTTP_PROXY=
TOOL_HTTPS_PROXY=

# 自動上下文壓縮（預設永遠啟用）
# 剩餘空間低於此值時觸發壓縮；代表 LLM 輸出所需最小緩衝，切換模型通常不需調整此值
COMPRESS_REMAINING_TOKENS=20000
# 模型上下文窗口大小；切換模型時更新此值，壓縮閾值自動對應
CONTEXT_WINDOW_SIZE=168000
# 壓縮後保留的最近訊息條數（不納入摘要，作為近期上下文）
COMPRESS_KEEP_RECENT=10